# Full demo configuration.
# Copy this file to .env, then fill DASHSCOPE_API_KEY before running Milvus RAG,
# semantic cache, long-term memory, or Qwen-Image poster generation.

DASHSCOPE_API_KEY=replace_with_your_dashscope_api_key

# Keep LLM inference local for the main chat flow.
LLM_PROVIDER=ollama
MODEL=qwen2.5:7b
BASE_URL=http://127.0.0.1:11434/v1

# Required for Milvus RAG, semantic cache, and long-term memory.
EMBEDDING_PROVIDER=dashscope

REDIS_URL=redis://localhost:6379
REDIS_TTL=1800

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=RootPass123!
MYSQL_DATABASE=cloud_platform

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

MILVUS_HOST=localhost
MILVUS_PORT=19530

# LangGraph checkpoint persistence. The SQLite file is ignored by Git.
LANGGRAPH_CHECKPOINT_ENABLED=true
LANGGRAPH_CHECKPOINT_PATH=data/langgraph_checkpoints.sqlite
