# Container deployment configuration.
# Copy this file to .env.container, then fill DASHSCOPE_API_KEY before starting
# the enterprise compose stack. Do not commit .env.container.

DASHSCOPE_API_KEY=replace_with_your_dashscope_api_key

# The backend container talks to Ollama on the host machine.
LLM_PROVIDER=ollama
MODEL=qwen2.5:7b
BASE_URL=http://host.docker.internal:11434/v1

# Required for Milvus RAG, semantic cache, and long-term memory.
EMBEDDING_PROVIDER=dashscope

REDIS_URL=redis://redis:6379
REDIS_TTL=1800

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=RootPass123!
MYSQL_DATABASE=cloud_platform

NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

MILVUS_HOST=milvus
MILVUS_PORT=19530

LANGGRAPH_CHECKPOINT_ENABLED=true
LANGGRAPH_CHECKPOINT_PATH=/app/data/langgraph_checkpoints.sqlite

# Lightweight runtime protection for internal pilots.
CHAT_RATE_LIMIT=60
CHAT_RATE_LIMIT_WINDOW_SECONDS=60
CHAT_WORKFLOW_TIMEOUT_SECONDS=45
